        async function handleResetPassword() {
            const newPass    = document.getElementById('resetNewPass').value;
            const confirmPass = document.getElementById('resetConfirmPass').value;
            const token      = window._activeResetToken;

            if (!newPass || newPass.length < 6) {
                _setResetMsg('A senha deve ter pelo menos 6 caracteres.', 'err');
                return;
            }
            if (newPass !== confirmPass) {
                _setResetMsg('As senhas não coincidem.', 'err');
                return;
            }
            if (!token) {
                _setResetMsg('Token inválido. Feche e solicite um novo link.', 'err');
                return;
            }

            const btn = document.getElementById('btnResetSave');
            btn.disabled = true;
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Salvando...';
            _setResetMsg('Verificando token...', 'info');

            try {
                // Re-valida o token no Firestore (garante que nao expirou nem foi usado)
                const tokenRef = firebaseUtils.doc(db, 'artifacts', appId, 'public', 'data', 'resetTokens', token);
                const tokenDoc = await firebaseUtils.getDoc(tokenRef);

                if (!tokenDoc.exists() || tokenDoc.data().usedAt !== null || Date.now() > tokenDoc.data().expiresAt) {
                    _setResetMsg('Token expirado ou já utilizado. Solicite um novo link.', 'err');
                    btn.disabled = false;
                    btn.innerHTML = '<i class="fa-solid fa-floppy-disk"></i> Salvar Nova Senha';
                    return;
                }

                const { username } = tokenDoc.data();
                const newHash = await hashPassword(newPass);

                // Atualiza o passwordHash do usuario no Firestore
                await firebaseUtils.setDoc(
                    firebaseUtils.doc(db, 'artifacts', appId, 'public', 'data', 'users', username),
                    { passwordHash: newHash },
                    { merge: true }
                );

                // Marca token como usado (invalida para reuso)
                await firebaseUtils.setDoc(tokenRef, { usedAt: Date.now() }, { merge: true });

                // Limpa token da memoria
                window._activeResetToken = null;

                _setResetMsg('Senha alterada com sucesso!', 'ok');
                btn.innerHTML = '<i class="fa-solid fa-circle-check"></i> Concluído!';

                // Fecha o modal apos 2s e foca no login
                setTimeout(() => {
                    const rm = document.getElementById('resetModal');
