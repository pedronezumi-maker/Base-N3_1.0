            }
            // Ctrl+D: Toggle theme
            if ((e.ctrlKey || e.metaKey) && e.key === 'd') {
                e.preventDefault();
                toggleTheme();
                return;
            }
            // Ctrl+Enter: Ask AI
            if ((e.ctrlKey || e.metaKey) && e.key === 'Enter') {
                if (currentUser && document.getElementById('loginModal').classList.contains('hidden')) {
                    e.preventDefault();
                    askAI();
                }
                return;
            }
            // ?: Show shortcuts
            if (e.key === '?' && !e.ctrlKey && !e.metaKey && !['INPUT','TEXTAREA'].includes(document.activeElement.tagName)) {
                toggleModal('shortcutModal', true);
                return;
            }
        });

        window.onload = () => {
            if (localStorage.getItem('theme') === 'dark') document.documentElement.classList.add('dark');
            populateCategorySelect();
            checkCurrentSession(); 
            initFirebase().then(() => {
                checkResetTokenInUrl();
            }).catch(() => {
                checkResetTokenInUrl();
            });
            setupSearchDragAndDrop();
            
            // Apply saved view mode
            setViewMode(_currentViewMode);

            // Apply saved sort
            document.querySelectorAll('.sort-opt').forEach(btn => {
                btn.classList.toggle('text-primary', btn.dataset.sort === _currentSortMode);
                btn.classList.toggle('font-bold', btn.dataset.sort === _currentSortMode);
            });

            // Update fav count
            updateFavCount();
            
            const si = document.getElementById('searchInput');
            si.addEventListener('keypress', (e) => {
                if (e.key === 'Enter') { 
                    e.preventDefault(); 
                    addToSearchHistory(si.value.trim());
                    document.getElementById('searchHistoryDropdown').classList.add('hidden');
                    askAI(); 
                }
            });
            si.addEventListener('keydown', (e) => {
                if (e.key === 'Escape') { e.preventDefault(); clearSearch(); si.blur(); }
            });

            // ── Field-hint tooltips: portal popup (hover desktop + touch mobile) ──────
            // O popup é renderizado no <body> via position:fixed, evitando clipping
            // de scroll containers e overflow horizontal dentro dos modais.

            function _showFieldHint(btn) {
                const src = btn.closest('.field-hint-wrap')?.querySelector('.field-hint-tooltip');
                if (!src) return;
                const popup = document.getElementById('fieldHintPopup');
                const isRight = src.classList.contains('tooltip-right');
                popup.innerHTML = src.innerHTML;
                popup.style.maxWidth = src.classList.contains('w-72') ? '18rem' : '16rem';
                popup.classList.toggle('arrow-right', isRight);
                popup.classList.toggle('arrow-left', !isRight);
                popup.classList.remove('arrow-below');
                // Medir dimensões antes de posicionar
                popup.style.top = '-9999px';
                popup.style.left = '0';
                popup.style.opacity = '1';
                popup.style.transform = 'translateY(0)';
                const pw = popup.offsetWidth;
                const ph = popup.offsetHeight;
                const rect = btn.getBoundingClientRect();
                let left = isRight ? rect.right - pw : rect.left;
                left = Math.max(8, Math.min(left, window.innerWidth - pw - 8));
                let top = rect.top - ph - 10;
                if (top < 8) { top = rect.bottom + 10; popup.classList.add('arrow-below'); }
                popup.style.left = left + 'px';
                popup.style.top  = top  + 'px';
                btn._hintActive = true;
            }

            function _hideFieldHint(btn) {
                const popup = document.getElementById('fieldHintPopup');
                popup.style.opacity = '0';
                popup.style.transform = 'translateY(4px)';
                if (btn) btn._hintActive = false;
            }

            // Hover: desktop
            document.querySelectorAll('.field-hint-wrap').forEach(wrap => {
                const btn = wrap.querySelector('.field-hint-btn');
                wrap.addEventListener('mouseenter', () => _showFieldHint(btn));
                wrap.addEventListener('mouseleave', () => _hideFieldHint(btn));
                btn.addEventListener('focus', () => _showFieldHint(btn));
                btn.addEventListener('blur',  () => _hideFieldHint(btn));
            });

            // Click/touch: mobile (dispositivos sem hover) + teclado
            const _hasHover = window.matchMedia('(hover: hover)').matches;
            document.addEventListener('click', (e) => {
                const btn = e.target.closest('.field-hint-btn');
                if (btn) {
                    e.stopPropagation();
                    if (!_hasHover) {
                        btn._hintActive ? _hideFieldHint(btn) : _showFieldHint(btn);
                    }
                } else if (!e.target.closest('#fieldHintPopup')) {
                    _hideFieldHint(null);
                }
            });
        };
    </script>

    <!-- Portal para tooltips de dicas de campo — fora de scroll containers para evitar clipping -->
    <div id="fieldHintPopup"
         class="fixed z-[250] pointer-events-none opacity-0 bg-slate-800 text-slate-200 rounded-xl shadow-2xl"
         style="padding:10px 12px;max-width:18rem;transform:translateY(4px);transition:opacity 0.2s,transform 0.2s;"></div>
</body>
</html>
