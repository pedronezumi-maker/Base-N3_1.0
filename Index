        // Funcao de Arrastar e Soltar (Drag and Drop)
        function setupSearchDragAndDrop() {
            const dropZone = document.getElementById('searchWrapper');
            const overlay = document.getElementById('dragOverlay');
            const fileInput = document.getElementById('aiAttachment');

            if (!dropZone || !overlay || !fileInput) return;

            // Previne comportamento padrao do navegador
            ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
                dropZone.addEventListener(eventName, preventDefaults, false);
            });

            function preventDefaults(e) {
                e.preventDefault();
                e.stopPropagation();
            }

            // Controle Visual
            dropZone.addEventListener('dragenter', () => {
                overlay.classList.remove('hidden');
                overlay.classList.add('flex');
                dropZone.classList.add('drag-active');
            });

            dropZone.addEventListener('dragleave', (e) => {
                // So remove se o mouse sair realmente do elemento pai
                if (!dropZone.contains(e.relatedTarget)) {
                    overlay.classList.add('hidden');
                    overlay.classList.remove('flex');
                    dropZone.classList.remove('drag-active');
                }
            });

            dropZone.addEventListener('drop', (e) => {
                overlay.classList.add('hidden');
                overlay.classList.remove('flex');
                dropZone.classList.remove('drag-active');

                const dt = e.dataTransfer;
                const files = dt.files;

                if (files.length > 0) {
                    const file = files[0];
                    if (file.type.startsWith('image/')) {
                        // Associa o arquivo ao input hidden
                        fileInput.files = files;
                        
                        // Atualiza icone visualmente
                        const btn = document.getElementById('aiAttachmentIcon');
                        btn.classList.remove('fa-paperclip');
                        btn.classList.add('fa-file-image', 'text-primary');
                        
                        showToast("Imagem solta! Iniciando análise...", "blue");
                        
                        // INICIA ANALISE DA IA AUTOMATICAMENTE
                        askAI();
                    } else {
                        showToast("Apenas imagens são aceitas aqui.", "red");
                    }
                }
            });
        }

