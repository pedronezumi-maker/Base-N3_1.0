<!DOCTYPE html>
<html lang="pt-BR" class="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <meta name="referrer" content="no-referrer">
    <title>Manual Operacional N3 - Access.Run (Master)</title>
    
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        primary: '#561c84', // Roxo Access Run
                        secondary: '#eceff4', // Cinza Claro Access Run
                        dark: '#0f172a', // Slate 900
                    },
                    zIndex: {
                        '60': '60', '70': '70', '80': '80', '90': '90', '100': '100'
                    }
                }
            }
        }
    </script>

    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
    <!-- EmailJS - disparo de e-mail client-side para recuperacao de senha -->
    <script src="https://cdn.jsdelivr.net/npm/@emailjs/browser@4/dist/email.min.js"></script>

    <!-- PDF.js para Extracao de Texto no Front-end (RAG) -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
    <script>
        pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';
    </script>

    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-app.js";
        import { getAuth, signInWithCustomToken, signInAnonymously, onAuthStateChanged } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-auth.js";
        import { getFirestore, doc, setDoc, getDoc, deleteDoc, collection, onSnapshot, query, getDocs, writeBatch } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-firestore.js";

        window.firebaseUtils = { initializeApp, getAuth, signInWithCustomToken, signInAnonymously, onAuthStateChanged, getFirestore, doc, setDoc, getDoc, deleteDoc, collection, onSnapshot, query, getDocs, writeBatch };
        window.dispatchEvent(new Event('firebase-ready'));
    </script>

    <style>
        /* Barra de rolagem personalizada */
        ::-webkit-scrollbar { width: 6px; height: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 3px; }
        .dark ::-webkit-scrollbar-thumb { background: #475569; }

        /* Efeitos de Hover nos Cards */
        .kb-card { transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); }
        .kb-card:hover { transform: translateY(-6px) scale(1.01); box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04); }

        /* Animacoes */
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
        .animate-fade-in { animation: fadeIn 0.4s ease-out forwards; }

        /* Destacar Termos de Pesquisa */
        mark { background-color: #fef08a; color: #854d0e; padding: 0 2px; border-radius: 2px; }
        .dark mark { background-color: #854d0e; color: #fef08a; }

        /* Animacao de Carregamento */
        .loader { border: 3px solid rgba(255,255,255,0.3); border-radius: 50%; border-top: 3px solid #561c84; width: 24px; height: 24px; animation: spin 1s linear infinite; }
        @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }

        /* Estilos Markdown */
        .prose h3 { font-size: 1.1em; font-weight: bold; margin-top: 1em; color: #1e293b; }
        .dark .prose h3 { color: #e2e8f0; }
        .prose ul { list-style-type: disc; padding-left: 1.5em; margin: 0.5em 0; }
        .prose strong { color: #561c84; }
        .dark .prose strong { color: #a78bfa; }

        /* Correcoes de Modal para Mobile */
        body.modal-open { overflow: hidden; width: 100%; }
        .modal-backdrop { -webkit-tap-highlight-color: transparent; }
        
        /* Zoom do cursor para miniaturas */
        .cursor-zoom-in { cursor: zoom-in; }

        /* Botoes de Navegacao da Galeria */
        .gallery-nav-btn {
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            background-color: rgba(0, 0, 0, 0.5);
            color: white;
            padding: 10px;
            border-radius: 50%;
            cursor: pointer;
            font-size: 20px;
            transition: background 0.3s;
            z-index: 110;
        }
        .gallery-nav-btn:hover { background-color: rgba(0, 0, 0, 0.8); }
        .gallery-prev { left: 10px; }
        .gallery-next { right: 10px; }

        /* Animacao de Sobreposicao de Arraste */
        .drag-active {
            border-color: #561c84 !important;
            background-color: rgba(86, 28, 132, 0.05) !important;
        }

        /* Animacao de Pulso na Indexacao RAG */
        .indexing-pulse { animation: pulseBg 1.5s infinite; }
        @keyframes pulseBg { 0% { opacity: 1; } 50% { opacity: 0.5; } 100% { opacity: 1; } }

        /* ========== NOVAS MELHORIAS ========== */

        /* Botão Scroll to Top */
        #scrollTopBtn { 
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            bottom: 5rem;
        }
        @media (min-width: 768px) {
            #scrollTopBtn { bottom: 1.5rem; }
        }

        /* Mobile Bottom Navigation */
        #mobileBottomNav {
            padding-bottom: env(safe-area-inset-bottom, 0px);
        }

        /* Search History Dropdown */
        #searchHistoryDropdown {
            animation: fadeIn 0.15s ease-out;
        }
        #searchHistoryDropdown li:hover {
            background: #f1f5f9;
        }
        .dark #searchHistoryDropdown li:hover {
            background: #334155;
        }

        /* List View Cards */
        .list-view .kb-card {
            flex-direction: row;
            align-items: center;
            padding: 0.875rem 1rem;
            gap: 1rem;
        }
        .list-view .kb-card:hover { transform: translateX(3px) scale(1); box-shadow: 2px 0 12px rgba(86,28,132,0.08); }
        .list-view .kb-card .card-thumbnail-wrap { display: none; }
        .list-view .kb-card .card-body { flex: 1; min-width: 0; }
        .list-view .kb-card .card-problem { display: none; }
        .list-view .kb-card .card-audit { display: none; }
        .list-view .kb-card .card-actions-row { border: none; padding-top: 0; margin-top: 0; }
        .list-view #gridContainer { grid-template-columns: 1fr; gap: 0.5rem; }

        /* Skeleton Loading */
        @keyframes shimmer {
            0% { background-position: -1000px 0; }
            100% { background-position: 1000px 0; }
        }
        .skeleton {
            background: linear-gradient(90deg, #f1f5f9 25%, #e2e8f0 50%, #f1f5f9 75%);
            background-size: 1000px 100%;
            animation: shimmer 1.5s infinite;
            border-radius: 0.5rem;
        }
        .dark .skeleton {
            background: linear-gradient(90deg, #1e293b 25%, #334155 50%, #1e293b 75%);
            background-size: 1000px 100%;
        }

        /* Favorite star */
        .btn-fav.active i { color: #f59e0b; }
        .btn-fav i { transition: transform 0.2s, color 0.2s; }
        .btn-fav:hover i { transform: scale(1.3); }

        /* Keyboard shortcut badge */
        kbd {
            background: #f1f5f9;
            border: 1px solid #cbd5e1;
            border-radius: 4px;
            padding: 1px 6px;
            font-size: 11px;
            font-family: monospace;
        }
        .dark kbd {
            background: #334155;
            border-color: #475569;
            color: #e2e8f0;
        }

        /* Connection status dot */
        .status-dot {
            width: 8px; height: 8px;
            border-radius: 50%;
            display: inline-block;
        }
        .status-dot.online { background: #10b981; box-shadow: 0 0 0 2px rgba(16,185,129,0.25); }
        .status-dot.offline { background: #f59e0b; box-shadow: 0 0 0 2px rgba(245,158,11,0.25); }

        /* Floating AI quick action button on mobile */
        #mobileAiBtn {
            box-shadow: 0 4px 24px rgba(86,28,132,0.4);
        }

        /* Smooth sidebar active state */
        .cat-btn.active-cat {
            background: #eceff4;
            color: #561c84;
            font-weight: 700;
        }
        .dark .cat-btn.active-cat {
            background: #334155;
            color: #fff;
        }

        /* Shortcut help modal */
        #shortcutModal .shortcut-row:nth-child(even) {
            background: rgba(241,245,249,0.5);
        }
        .dark #shortcutModal .shortcut-row:nth-child(even) {
            background: rgba(30,41,59,0.5);
        }

        /* ========== FIELD HINTS & VALIDATION ========== */
        .field-hint-tooltip {
            position: absolute;
            bottom: calc(100% + 6px);
            left: 0;
            right: 0;
            z-index: 200;
            background: #1e293b;
            color: #e2e8f0;
            font-size: 11px;
            line-height: 1.5;
            padding: 10px 12px;
            border-radius: 8px;
            box-shadow: 0 8px 24px rgba(0,0,0,0.25);
            pointer-events: none;
            opacity: 0;
            transform: translateY(4px);
            transition: opacity 0.2s, transform 0.2s;
            white-space: normal;
        }
        .field-hint-tooltip::after {
            content: '';
            position: absolute;
            top: 100%;
            left: 16px;
            border: 5px solid transparent;
            border-top-color: #1e293b;
        }
        .field-hint-tooltip.tooltip-right {
            left: auto;
            right: 0;
        }
        .field-hint-tooltip.tooltip-right::after {
            left: auto;
            right: 16px;
        }

        /* Portal popup — renderizado no <body>, fora de qualquer scroll container */
        /* Evita clipping e overflow horizontal dentro dos modais                  */
        #fieldHintPopup {
            top: 0; left: 0;
            white-space: normal;
            line-height: 1.5;
            font-size: 11px;
        }
        #fieldHintPopup::after {
            content: '';
            position: absolute;
            top: 100%;
            border: 5px solid transparent;
            border-top-color: #1e293b;
        }
        #fieldHintPopup.arrow-left::after  { left: 16px; }
        #fieldHintPopup.arrow-right::after { right: 16px; left: auto; }
        #fieldHintPopup.arrow-below::after { display: none; }

        /* Tooltips originais viram apenas "fontes de conteúdo"; o popup portal exibe */
        .field-hint-wrap .field-hint-tooltip { display: none !important; }
        .field-hint-wrap:hover .field-hint-tooltip,
        .field-hint-btn:focus + .field-hint-tooltip,
        .field-hint-btn.active + .field-hint-tooltip {
            opacity: 1;
            transform: translateY(0);
        }
        .field-hint-btn {
            cursor: pointer;
            color: #94a3b8;
            transition: color 0.15s;
            background: none;
            border: none;
            padding: 0;
            font-size: 11px;
        }
        .field-hint-btn:hover { color: #561c84; }

        /* Character counter */
        .char-counter {
            font-size: 10px;
            transition: color 0.2s;
        }
        .char-counter.warn { color: #f59e0b; }
        .char-counter.danger { color: #ef4444; font-weight: bold; }

        /* Quality indicator bar */
        .quality-bar-wrap {
            height: 3px;
            background: #e2e8f0;
            border-radius: 99px;
            margin-top: 4px;
            overflow: hidden;
        }
        .dark .quality-bar-wrap { background: #334155; }
        .quality-bar {
            height: 100%;
            border-radius: 99px;
            transition: width 0.4s, background-color 0.4s;
        }

        /* Refine button */
        .btn-refine {
            font-size: 10px;
            padding: 2px 8px;
            border-radius: 6px;
            border: 1px solid #ddd6fe;
            color: #561c84;
            background: #f5f3ff;
            cursor: pointer;
            transition: all 0.15s;
            display: inline-flex;
            align-items: center;
            gap: 4px;
        }
        .dark .btn-refine {
            border-color: #4c1d95;
            color: #a78bfa;
            background: #1e1b4b;
        }
        .btn-refine:hover {
            background: #561c84;
            color: #fff;
            border-color: #561c84;
        }
        .btn-refine:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }
    </style>
</head>
<body class="bg-slate-50 text-slate-800 dark:bg-slate-900 dark:text-slate-200 transition-colors duration-300 h-screen flex overflow-hidden font-sans">

    <div id="loginModal" class="fixed inset-0 bg-slate-900 z-80 flex items-center justify-center p-4">
        <div class="bg-white dark:bg-slate-800 rounded-2xl shadow-2xl w-full max-w-sm p-8 text-center border border-slate-200 dark:border-slate-700">
            <div class="mb-6 flex justify-center">
                <span class="w-16 h-16 bg-secondary dark:bg-slate-700 rounded-full flex items-center justify-center text-primary dark:text-white text-3xl">
                    <i class="fa-solid fa-lock"></i>
                </span>
            </div>
            <h2 class="text-2xl font-bold text-slate-800 dark:text-white mb-2">Acesso Restrito</h2>
            <p class="text-sm text-slate-500 dark:text-slate-400 mb-6">Identifique-se para acessar o Manual Operacional N3.</p>
            
            <form onsubmit="handleLogin(event)" autocomplete="off" class="space-y-4 text-left">
                <input style="display:none" type="text" name="fakeusernameremembered"/>
                <input style="display:none" type="password" name="fakepasswordremembered"/>

                <div>
                    <label class="block text-xs font-bold text-slate-700 dark:text-slate-300 mb-1 ml-1">Usuário</label>
                    <div class="relative">
                        <span class="absolute inset-y-0 left-0 pl-3 flex items-center text-slate-400"><i class="fa-solid fa-user"></i></span>
                        <input type="text" id="loginUser" autocomplete="off" class="w-full pl-10 pr-3 py-2.5 bg-slate-50 dark:bg-slate-700 border border-slate-300 dark:border-slate-600 rounded-lg text-sm focus:ring-2 focus:ring-primary outline-none transition-all" placeholder="Digite seu usuário" required>
                    </div>
                </div>
                <div>
                    <label class="block text-xs font-bold text-slate-700 dark:text-slate-300 mb-1 ml-1">Senha</label>
                    <div class="relative">
                        <span class="absolute inset-y-0 left-0 pl-3 flex items-center text-slate-400"><i class="fa-solid fa-key"></i></span>
                        <input type="password" id="loginPass" autocomplete="new-password" class="w-full pl-10 pr-10 py-2.5 bg-slate-50 dark:bg-slate-700 border border-slate-300 dark:border-slate-600 rounded-lg text-sm focus:ring-2 focus:ring-primary outline-none transition-all" placeholder="Digite sua senha" required>
                        <button type="button" onclick="toggleLoginPassVisibility()" class="absolute inset-y-0 right-0 pr-3 flex items-center text-slate-400 hover:text-primary transition-colors" tabindex="-1">
                            <i id="loginPassEyeIcon" class="fa-solid fa-eye text-sm"></i>
                        </button>
                    </div>
                </div>
                <div id="loginError" class="text-red-500 text-xs text-center font-bold hidden bg-red-50 dark:bg-red-900/20 p-2 rounded">
                    Usuário ou senha incorretos.
                </div>
                <button type="submit" class="w-full bg-primary hover:bg-purple-800 text-white font-bold py-3 rounded-lg shadow-lg shadow-purple-900/20 transition-all active:scale-95 mt-2">
                    Entrar no Sistema
                </button>
            </form>
            <button type="button" onclick="openForgotPassword()" class="mt-4 text-xs text-primary dark:text-purple-400 hover:underline font-medium transition-colors">
                Esqueci minha senha
            </button>
            <p id="envIndicator" class="mt-3 text-xs text-slate-400">Protegido por criptografia SHA-256 e Firestore</p>
        </div>
    </div>

