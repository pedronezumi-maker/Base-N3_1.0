        // ETAPA 1 - Funcao de merge com deduplicacao absoluta e blindagem do banco
        function getAllData() {
            const staticData = window.staticPlaybook || [];
            const uniqueMap = new Map();

            // 1. Ingestao da Base Estatica (Garante que se database.js tiver duplicatas, apenas 1 sobrevive)
            staticData.forEach(item => {
                if (!item.deleted) {
                    uniqueMap.set(String(item.id), item);
                }
            });

            // 2. Sobreposicao com a Base Dinamica (Nuvem via Firestore ou Local Storage)
            if (firebaseOnline) {
                firestorePlaybook.forEach(item => {
                    if (item.deleted) {
                        uniqueMap.delete(String(item.id));
                    } else {
                        uniqueMap.set(String(item.id), { ...item, source: 'cloud' });
                    }
                });
            } else {
                customPlaybook.forEach(item => {
                    if (item.deleted) {
                        uniqueMap.delete(String(item.id));
                    } else {
                        uniqueMap.set(String(item.id), { ...item, source: 'local' });
                    }
                });
            }

            // 3. Retorna os dados puros, unicos e prontos para renderizar na tela
            // Tópicos com hidden:true são visíveis apenas para admins
            const allItems = Array.from(uniqueMap.values());
            if (currentUser?.role === 'admin') return allItems;
            return allItems.filter(item => !item.hidden);
        }

