        async function handleLogin(event) {
            event.preventDefault();
            const user = document.getElementById('loginUser').value.trim();
            const pass = document.getElementById('loginPass').value.trim();
            const errorMsg = document.getElementById('loginError');

            const submitBtn = event.target.querySelector('button[type="submit"]');
            const originalBtnText = submitBtn.innerHTML;
            submitBtn.disabled = true;
            submitBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin mr-2"></i>Verificando...';

            try {
                const inputHash = await hashPassword(pass);
                const localUsers = JSON.parse(localStorage.getItem('accessRunUsers') || '[]');
                const allUsers = firebaseOnline ? firestoreUsers : localUsers;
                const foundUser = allUsers.find(u => u.username.toLowerCase() === user.toLowerCase() && u.passwordHash === inputHash);

                if (foundUser) {
                    _loginFailCount = 0; // reset contador em login bem-sucedido
                    loginSuccess(foundUser.username, foundUser.role);
                } else {
                    _loginFailCount = (_loginFailCount || 0) + 1;
                    errorMsg.classList.remove('hidden');
                    // Delay progressivo: 1s, 2s, 4s, 8s... (cap 15s) — desacelera brute-force
                    const delay = Math.min(1000 * Math.pow(2, _loginFailCount - 1), 15000);
                    await new Promise(r => setTimeout(r, delay));
                }
            } finally {
                submitBtn.disabled = false;
                submitBtn.innerHTML = originalBtnText;
            }
        }

