                        <span class="font-bold text-primary dark:text-purple-400"><i class="fa-solid fa-file-lines mr-1"></i> ${escapeHtml(doc.name)}</span>
                        ${chunksCount > 0 ? `<p class="text-[9px] text-emerald-600 dark:text-emerald-400 mt-0.5"><i class="fa-solid fa-brain"></i> Indexado: ${chunksCount} vetores</p>` : ''}
                    </div>
                    <button type="button" onclick="removeDoc(${index})" class="text-red-500 hover:text-red-700 p-1"><i class="fa-solid fa-times"></i></button>
                `;
                container.appendChild(div);
