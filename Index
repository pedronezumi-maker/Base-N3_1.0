        async function askAI() {
            let queryText = document.getElementById('searchInput').value;
            
            // Apaga a pesquisa anterior da barra de pesquisa imediatamente apos o envio
            document.getElementById('searchInput').value = '';
            
            // Suporte a envio vazio se houver imagem (Disparo automatico)
