        // ... funcoes de importacao/exportacao ...
        async function importDatabase(input) {
            if (!input.files || !input.files[0]) return;
            if (!firebaseOnline) return alert("Você precisa estar online para importar para a nuvem.");
            const file = input.files[0];
            // Limite de 5MB para evitar travamento do browser com arquivos gigantes
            if (file.size > 5 * 1024 * 1024) {
                alert("Arquivo muito grande. O limite para importação é de 5MB.");
                input.value = "";
                return;
            }
            const reader = new FileReader();
            reader.onload = async function(e) {
                const content = e.target.result;
                try {
                    // FIX CRITICO: Parser robusto para JavaScript/JSON misto
                    const startIdx = content.indexOf('[');
                    const endIdx = content.lastIndexOf(']');
                    
                    if (startIdx !== -1 && endIdx !== -1) {
                        const jsonStr = content.substring(startIdx, endIdx + 1);
                        let data;
                        
                        try {
                            data = JSON.parse(jsonStr);
                        } catch (e) {
                            throw new Error("Arquivo inválido: apenas JSON puro é aceito na importação.");
                        }
                        
                        if (confirm(`Importar ${data.length} registros para a nuvem?`)) {
                            showToast("Iniciando upload em massa...", "blue");
                            
                            // FIX CRITICO: Batch Write com Chunking (50 itens por lote)
                            const chunkSize = 50;
                            for (let i = 0; i < data.length; i += chunkSize) {
                                const chunk = data.slice(i, i + chunkSize);
                                const batch = firebaseUtils.writeBatch(db);
                                
                                chunk.forEach(item => {
                                    let cloudId = item.id;
                                    if (cloudId.startsWith('CUSTOM-')) cloudId = cloudId.replace('CUSTOM-', 'FIRE-');
                                    
                                    const docRef = firebaseUtils.doc(db, 'artifacts', appId, 'public', 'data', 'playbook', cloudId);
                                    // Garante merge para nao apagar dados existentes
                                    batch.set(docRef, item, { merge: true });
                                });

                                await batch.commit();
                                // lote enviado (log removido de produção)
                            }

                            alert(`Sucesso! ${data.length} registros importados para a nuvem.`);
                        }
                    } else {
                        alert("Formato do arquivo inválido: Array não encontrado.");
                    }
                } catch (err) {
                    console.error(err);
                    alert("Erro ao processar arquivo: " + err.message);
                }
            };
            reader.readAsText(file);
        }

