        async function handleForgotPassword() {
            const usernameInput = document.getElementById('forgotUsername').value.trim();
            if (!usernameInput) { _setForgotMsg('Digite seu nome de usuário.', 'err'); return; }

            // Verificacao de pre-requisitos
            if (!firebaseOnline) {
                _setForgotMsg('Esta função requer conexão com a nuvem (Firestore).', 'err');
                return;
            }
            if (typeof emailjs === 'undefined' || EMAILJS_PUBLIC_KEY === 'SUA_PUBLIC_KEY') {
                _setForgotMsg('Serviço de e-mail não configurado. Contacte o administrador.', 'err');
                return;
            }

            const btn = document.getElementById('btnForgotSend');
            btn.disabled = true;
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Verificando...';
            _setForgotMsg('Buscando usuário...', 'info');

            try {
                // Resposta generica para nao vazar se o usuario existe ou nao
                const genericMsg = 'Se o usuário existir e possuir e-mail cadastrado, o link será enviado em instantes.';

                // Busca case-insensitive nos usuarios ja carregados em memoria
                // (firestoreUsers é o array sincronizado pelo onSnapshot)
                const matchedUser = firestoreUsers.find(
                    u => u.username.toLowerCase() === usernameInput.toLowerCase()
                );

                if (!matchedUser) {
                    _setForgotMsg(genericMsg, 'ok');
                    btn.disabled = false;
                    btn.innerHTML = '<i class="fa-solid fa-paper-plane"></i> Enviar Link de Redefinição';
                    return;
                }

                // Busca o documento real usando o username exato (como esta salvo no Firestore)
                const userDoc = await firebaseUtils.getDoc(
                    firebaseUtils.doc(db, 'artifacts', appId, 'public', 'data', 'users', matchedUser.username)
                );

                if (!userDoc.exists()) {
                    _setForgotMsg(genericMsg, 'ok');
                    btn.disabled = false;
                    btn.innerHTML = '<i class="fa-solid fa-paper-plane"></i> Enviar Link de Redefinição';
                    return;
                }

                const userData = userDoc.data();
                if (!userData.email) {
                    _setForgotMsg('Este usuário não possui e-mail cadastrado. Solicite ao administrador que cadastre um e-mail na sua conta.', 'err');
                    btn.disabled = false;
                    btn.innerHTML = '<i class="fa-solid fa-paper-plane"></i> Enviar Link de Redefinição';
                    return;
                }

                // Gera e salva o token no Firestore com TTL
                const token = generateResetToken();
                const expiresAt = Date.now() + RESET_TOKEN_TTL_MS;
                await firebaseUtils.setDoc(
                    firebaseUtils.doc(db, 'artifacts', appId, 'public', 'data', 'resetTokens', token),
                    { username: matchedUser.username, expiresAt, usedAt: null } // username canônico do banco
                );

                // Monta o link de reset com o token na URL
                const resetLink = `${window.location.href.split('?')[0]}?reset=${token}`;

                // Dispara o e-mail via EmailJS
                btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Enviando e-mail...';
                await emailjs.send(EMAILJS_SERVICE_ID, EMAILJS_TEMPLATE_ID, {
                    to_email:   userData.email,
                    email:      userData.email,   // compatibilidade: campo "To Email" do template usa {{email}}
                    username:   userData.username,
                    reset_link: resetLink
                });

                _setForgotMsg('Link enviado! Verifique sua caixa de entrada (e a pasta de spam).', 'ok');
                btn.innerHTML = '<i class="fa-solid fa-circle-check"></i> Enviado!';

            } catch (err) {
                console.error('Erro ao enviar reset:', err);
                _setForgotMsg('Falha ao enviar. Tente novamente ou contacte o administrador.', 'err');
                btn.disabled = false;
