                console.error('Erro ao redefinir senha:', err);
                _setResetMsg('Falha ao salvar. Tente novamente.', 'err');
                btn.disabled = false;
                btn.innerHTML = '<i class="fa-solid fa-floppy-disk"></i> Salvar Nova Senha';
            }
        }

