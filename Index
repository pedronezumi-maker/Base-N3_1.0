        // Lida com o File Reader para Documentos (Indexacao RAG)
        document.getElementById('entryDocs').addEventListener('change', async function(e) {
            const files = Array.from(e.target.files);
            if (files.length === 0) return;

            const loader = document.getElementById('docIndexLoader');
            if (loader) loader.classList.remove('hidden');
            const apiKey = await getGeminiKey();

            for (const file of files) {
                if (file.size > 500 * 1024) { // 500KB Limit para evitar estourar o 1MB do Firestore com Base64
                    alert(`O documento ${file.name} excede o limite de 500KB. Isso causará falha ao salvar no banco.`);
                    continue;
                }
                
                const reader = new FileReader();
                reader.readAsDataURL(file);
                reader.onload = async (event) => {
                    const dataUrl = event.target.result;
                    let rawText = "";

                    try {
                        if (file.type === 'application/pdf') {
                            rawText = await extractTextFromPDF(dataUrl);
                        } else if (file.type === 'text/plain') {
                            rawText = await new Promise(res => {
                                const txtReader = new FileReader();
                                txtReader.onload = (ev) => res(ev.target.result);
                                txtReader.readAsText(file);
                            });
                        }

                        // Se nao extraiu texto, salva como documento comum
                        if (!rawText || !rawText.trim()) {
                            currentBase64Docs.push({ name: file.name, type: file.type, data: dataUrl });
                            renderDocPreviews();
                            return;
                        }

                        // Dividir em blocos e gerar Embed via Gemini Text-Embedding
                        const chunksArray = chunkText(rawText);
                        const embeddingsObj = [];
                        
                        for(const chunkStr of chunksArray) {
                            if(chunkStr.length < 10) continue;
                            const vector = await getEmbedding(chunkStr, apiKey);
                            if(vector) {
                                // Forca array numerico limpo para seguranca do JSON.stringify
                                embeddingsObj.push({ text: chunkStr, vector: Array.from(vector) });
                            }
                        }

                        currentBase64Docs.push({
                            name: file.name,
                            type: file.type,
                            data: dataUrl,
                            rawText: rawText.substring(0, 3000), // Limite de caracteres para preview/save
                            // FIX CRITICO: JSON.stringify evita o erro de "nested entity" do Firestore (arrays dentro de arrays).
                            chunks: JSON.stringify(embeddingsObj), 
                            createdAt: new Date().toISOString()
                        });
                        
                        renderDocPreviews();
                    } catch (err) {
                        console.error("Erro na extração de texto", err);
                        alert(`Erro ao processar conteúdo de ${file.name}`);
                    }
                };
            }
            
            setTimeout(() => { if (loader) loader.classList.add('hidden'); this.value = ""; }, 2000);
        });

        function renderDocPreviews() {
            const container = document.getElementById('docPreviewContainer');
            container.innerHTML = '';

            if (currentBase64Docs.length === 0) {
                container.classList.add('hidden');
                return;
            }

            container.classList.remove('hidden');
            currentBase64Docs.forEach((doc, index) => {
                let chunksCount = 0;
                if (doc.chunks) {
                    try { chunksCount = typeof doc.chunks === 'string' ? JSON.parse(doc.chunks).length : doc.chunks.length; } catch(e){}
                }

                const div = document.createElement('div');
                div.className = "flex items-center justify-between bg-slate-100 dark:bg-slate-700 p-2 rounded text-xs border border-slate-200 dark:border-slate-600";
