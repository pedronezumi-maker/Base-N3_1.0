            if (len > max * 0.9) counter.classList.add('danger');
            else if (len > max * 0.75) counter.classList.add('warn');
            else counter.style.color = '';
        }

        function updateQuality(fieldId, barId, thresholds) {
            const field = document.getElementById(fieldId);
            const bar = document.getElementById(barId);
            if (!field || !bar) return;
            const len = field.value.trim().length;
            let pct = 0, color = '#e2e8f0';
            if (len >= thresholds.good) { pct = 100; color = '#10b981'; }
            else if (len >= thresholds.min) { pct = 40 + ((len - thresholds.min) / (thresholds.good - thresholds.min)) * 60; color = '#f59e0b'; }
            else if (len > 0) { pct = (len / thresholds.min) * 40; color = '#ef4444'; }
            bar.style.width = pct + '%';
            bar.style.backgroundColor = color;
        }

