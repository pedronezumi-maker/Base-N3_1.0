        // Redimensiona a imagem para no maximo 1280px de largura/altura e converte para Base64 (Alta Qualidade)
        function resizeImage(file) {
            return new Promise((resolve, reject) => {
                const reader = new FileReader();
                reader.readAsDataURL(file);
                reader.onload = (event) => {
                    const img = new Image();
                    img.src = event.target.result;
                    img.onload = () => {
                        const canvas = document.createElement('canvas');
                        let width = img.width;
                        let height = img.height;
                        
                        // Alvo: HD (1280px) para melhor legibilidade
                        const MAX_WIDTH = 1280; 
                        const MAX_HEIGHT = 1280;

                        if (width > height) {
                            if (width > MAX_WIDTH) {
                                height *= MAX_WIDTH / width;
                                width = MAX_WIDTH;
                            }
                        } else {
                            if (height > MAX_HEIGHT) {
                                width *= MAX_HEIGHT / height;
                                height = MAX_HEIGHT;
                            }
                        }
                        canvas.width = width;
                        canvas.height = height;
                        const ctx = canvas.getContext('2d');
                        ctx.drawImage(img, 0, 0, width, height);
                        
                        // Tenta WebP primeiro (Alta eficiencia para texto)
                        let quality = 0.8;
                        let dataUrl = canvas.toDataURL('image/webp', quality);
                        
                        // Verifica se ocorreu fallback para PNG (navegador nao suporta WebP)
                        if (dataUrl.startsWith('data:image/png')) {
                            dataUrl = canvas.toDataURL('image/jpeg', 0.7); // Fallback para JPEG
                        }

                        // Verificacao de Seguranca: com até 15 imagens, limite conservador por imagem
                        // Firestore 1MB total; cada imagem deve ficar abaixo de ~60KB base64 (~80.000 chars)
                        if (dataUrl.length > 80000) {
                             const scale = 0.6;
                             canvas.width = Math.round(width * scale);
                             canvas.height = Math.round(height * scale);
                             ctx.drawImage(img, 0, 0, canvas.width, canvas.height);
                             dataUrl = canvas.toDataURL('image/jpeg', 0.55); 
                        }
                        // Segunda reducao se ainda grande
                        if (dataUrl.length > 80000) {
                             canvas.width = Math.round(width * 0.4);
                             canvas.height = Math.round(height * 0.4);
                             ctx.drawImage(img, 0, 0, canvas.width, canvas.height);
                             dataUrl = canvas.toDataURL('image/jpeg', 0.45);
                        }

                        resolve(dataUrl); 
                    };
                    img.onerror = (err) => reject(err);
                };
                reader.onerror = (err) => reject(err);
            });
        }

