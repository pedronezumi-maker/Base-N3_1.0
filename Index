        async function saveEntry() {
            if(!currentUser) return showToast("Sessão inválida", "red");
            const id = document.getElementById('entryId').value;
            const title = document.getElementById('entryTitle').value.trim();
            const category = document.getElementById('entryCategory').value;
            const problem = document.getElementById('entryProblem').value.trim();
            const step = document.getElementById('entryStep').value.trim();
            const script = document.getElementById('entryScript').value.trim();

            // --- CAMADA DE PERMISSAO E SEGURANCA (NOVA) ---
            if (id && currentUser?.role !== 'admin') {
                 const existingItem = getAllData().find(i => i.id === id);
                 const isManual = (id + "").startsWith('FIRE-') || (id + "").startsWith('CUSTOM-');
                 
                 if (!isManual) {
                     showToast("Permissão negada: Tópicos base do sistema não podem ser editados.", "red");
                     return;
                 }
                 if (existingItem && existingItem.createdBy !== currentUser.username) {
                     showToast("Permissão negada: Você só pode editar tópicos de sua autoria.", "red");
                     return;
                 }
            }
            // ----------------------------------------------

            if (id && currentUser.role === 'admin') {
                 if(!confirm("ATENÇÃO ADMINISTRADOR\n\nVocê está prestes a editar um tópico existente.\nEssa alteração impactará a base de conhecimento.\n\nDeseja confirmar a gravação?")) {
                    return;
                 }
            }

            if (!title || !problem || !step) return showToast("Preencha campos obrigatórios.", "red");
            // Validação de comprimento — evita payload excessivo no Firestore
            if (title.length > 120)   return showToast("Título muito longo (máx 120 caracteres).", "red");
            if (problem.length > 2000) return showToast("Problema muito longo (máx 2000 caracteres).", "red");
            if (step.length > 5000)   return showToast("Solução muito longa (máx 5000 caracteres).", "red");
            if (script.length > 1500) return showToast("Script muito longo (máx 1500 caracteres).", "red");
            
            // Validações de qualidade com alertas contextuais
            if (title.length < 10) return showToast("Título muito curto. Seja mais específico (mín. 10 caracteres).", "amber");
            if (problem.length < 20) return showToast("Problema/Contexto muito curto. Descreva melhor a ocorrência (mín. 20 caracteres).", "amber");
            if (step.length < 30) return showToast("Solução técnica muito curta. Detalhe os passos da resolução (mín. 30 caracteres).", "amber");
            
            // Aviso suave: solução sem numeração (não bloqueia, apenas orienta)
            if (step.length > 50 && !/\d\s*\.|^-|\n-/.test(step)) {
                const ok = confirm("⚡ Dica de qualidade: A solução técnica não parece estar em formato de passos numerados (ex: 1. ... 2. ...).\n\nDeseja continuar assim mesmo?\n\n(Clique em 'Cancelar' para ajustar e usar o botão 'Aprimorar' para formatar automaticamente)");
                if (!ok) return;
            }

            let finalId = id;
            if (!finalId) {
                finalId = firebaseOnline ? `FIRE-${Date.now()}` : `CUSTOM-${Date.now()}`;
            }

            const entryData = {
                title, category, problem, step, script,
                images: currentBase64Images, 
                image: currentBase64Images[0] || null,
                documents: currentBase64Docs, // Chunks ja estao stringificados (Firestore Seguro)
                createdBy: currentUser.username,
                createdAt: id ? (getAllData().find(i=>i.id===id)?.createdAt || new Date().toISOString()) : new Date().toISOString()
            };

            const saveBtn = document.getElementById('btnSaveEntry');
            const originalBtnText = saveBtn.innerText;
            saveBtn.innerText = "Salvando...";
            saveBtn.disabled = true;

            try {
                if (firebaseOnline) {
                    try {
                        await firebaseUtils.setDoc(firebaseUtils.doc(db, 'artifacts', appId, 'public', 'data', 'playbook', finalId), entryData);
                        closeModal('entryModal');
                        showToast("Sincronizado na nuvem.");
                    } catch(e) {
                        alert("Erro ao salvar na nuvem: " + e.message);
                    }
                } else {
                    const localEntry = { id: finalId, ...entryData };
                    const idx = customPlaybook.findIndex(p => p.id === finalId);
                    if (idx !== -1) customPlaybook[idx] = localEntry;
                    else customPlaybook.push(localEntry);
                    localStorage.setItem('accessRunCustomData', JSON.stringify(customPlaybook));
                    closeModal('entryModal');
                    renderSidebar();
                    _refreshCardsWithFilters();
                    alert("Registro salvo LOCALMENTE.");
                }
            } finally {
                saveBtn.innerText = originalBtnText;
                saveBtn.disabled = false;
            }
        }

        async function deleteEntry() {
            const id = document.getElementById('entryId').value;
            if (currentUser?.role !== 'admin') {
                alert("Ação não permitida. Apenas administradores podem excluir.");
                return;
            }
            if (!id || !confirm("Remover este registro?")) return;
            
            if (firebaseOnline) {
                try {
                    await firebaseUtils.setDoc(firebaseUtils.doc(db, 'artifacts', appId, 'public', 'data', 'playbook', id), { deleted: true }, { merge: true });
                    showToast("Removido da nuvem.");
                } catch (err) {
                    console.error(err);
                    alert("Erro ao excluir: " + err.message);
                }
            } else {
                const isStatic = window.staticPlaybook.some(i => i.id === id);
                if (isStatic) {
                    const tombstone = { id: id, deleted: true, updatedAt: new Date().toISOString() };
                    const existingIdx = customPlaybook.findIndex(p => p.id === id);
                    if (existingIdx >= 0) customPlaybook[existingIdx] = tombstone;
                    else customPlaybook.push(tombstone);
                } else {
                    customPlaybook = customPlaybook.filter(p => p.id !== id);
                }
                localStorage.setItem('accessRunCustomData', JSON.stringify(customPlaybook));
                renderSidebar();
                _refreshCardsWithFilters();
                showToast("Removido localmente.");
            }
            closeModal('entryModal');
        }

