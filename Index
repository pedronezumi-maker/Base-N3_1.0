            if (!queryText && !file) return showToast("Digite uma pergunta ou anexe uma imagem.", "blue");
            
            // Se houver imagem mas nao texto, define um prompt padrao
            if (file && !queryText) {
                queryText = "Analise este print de erro e identifique a solução.";
            }
            
            if (file && !file.type.startsWith('image/')) {
                 alert("Apenas imagens são permitidas para análise da IA neste campo. Para documentos, anexe no registro.");
                 return;
            }

            document.getElementById('btnCopyAi').classList.add('hidden'); // Esconde botao ao iniciar nova consulta
            document.getElementById('btnCreateEntry').classList.add('hidden');
            document.getElementById('btnEditAi').classList.add('hidden');
            _exitAiEditMode(false); // fecha modo edição sem salvar se estava aberto
            // Remove aviso de persistencia de edicao anterior, se existir
            const persistNotice = document.getElementById('aiEditPersistNotice');
            if (persistNotice) persistNotice.remove();

            let availableKeys = [...cloudApiKeys];
            if (availableKeys.length === 0) {
                 const stored = localStorage.getItem('secure_gemini_keys_multi');
                 if (stored) {
                     try { availableKeys = JSON.parse(stored); } catch(e) {}
                 }
                 if (availableKeys.length === 0) {
                    const local = localStorage.getItem('secure_gemini_token');
                    if (local) availableKeys.push(atob(local));
                 }
                 availableKeys.push(atob(_SK));
            }
            const panel = document.getElementById('aiPanel');
            const loader = document.getElementById('aiLoader');
            const content = document.getElementById('aiContent');
            panel.classList.remove('hidden');
            loader.classList.remove('hidden');
            content.innerHTML = '';

            // --- INICIO INJECAO RAG ---
            const apiKeyForEmbed = await getGeminiKey();
            const queryVector = await getEmbedding(queryText, apiKeyForEmbed);
            let topChunksContext = "";

            if (queryVector) {
                let allChunksScored = [];
                const dbItems = getAllData();
                
                dbItems.forEach(topic => {
                    if(topic.documents && topic.documents.length > 0) {
                        topic.documents.forEach(doc => {
                            if(doc.chunks) {
                                try {
                                    // Deserializa com seguranca os chunks em formato texto
                                    const parsedChunks = typeof doc.chunks === 'string' ? JSON.parse(doc.chunks) : doc.chunks;
                                    if (parsedChunks && parsedChunks.length > 0) {
                                        parsedChunks.forEach(chunk => {
                                            const sim = cosineSimilarity(queryVector, chunk.vector);
                                            allChunksScored.push({ 
                                                text: chunk.text, 
                                                sim: sim, 
                                                topicTitle: topic.title, 
                                                fileName: doc.name 
                                            });
                                        });
                                    }
                                } catch(e) { console.error("Erro na leitura RAG", e) }
                            }
                        });
                    }
                });

                allChunksScored.sort((a,b) => b.sim - a.sim);
                const topChunks = allChunksScored.filter(c => c.sim > 0.45).slice(0, 6);
                
                if (topChunks.length > 0) {
                    topChunksContext += "\n\n=== CONTEXTO EXTRAIDO DOS DOCUMENTOS ANEXADOS (RAG) ===\n";
                    topChunksContext += "Use EXCLUSIVAMENTE as informações abaixo para compor sua resposta se a pergunta for sobre elas:\n\n";
                    topChunks.forEach((c, idx) => {
                        topChunksContext += `[Documento ${idx+1}: "${c.fileName}" (Topico: ${c.topicTitle})]\nConteudo Extraido: ${c.text}\n\n`;
                    });
                }
            }
            // --- FIM INJECAO RAG ---
            
            const contextData = getAllData().map(p => ({ t: p.title, p: p.problem, s: p.step }));
            const contextString = JSON.stringify(contextData);
            
            let systemPrompt = `Você é o suporte técnico N3 (Especialista Avançado) do sistema Access.Run.
Sua missão é fornecer respostas de alta complexidade, extremamente detalhadas e com profundidade analítica.
Utilize EXCLUSIVAMENTE o contexto técnico fornecido abaixo, mas extraia e explique cada detalhe, processo e resolução de forma exaustiva.

Classifique internamente o tipo de pergunta antes de responder:

1. Dúvida operacional, erro, configuração, uso do sistema ou fluxo funcional:
Estruture a resposta obrigatoriamente da seguinte forma:
- Diagnóstico Profundo: Analise a raiz do problema com base no contexto. Explique tecnicamente o motivo da ocorrência.
- Resolução Detalhada: Forneça a ação recomendada, solução ou configuração em etapas claras, descrevendo exaustivamente o que cada passo faz no sistema e os processos envolvidos.
- Impacto e Fluxo: Explique o que essa resolução afeta no fluxo geral do Access.Run.
- Observações Adicionais: Detalhes relevantes do contexto para evitar problemas futuros.

2. Pergunta técnica específica, institucional ou de compliance:
Responda de forma altamente técnica, com riqueza de detalhes e descritiva, explicando:
- Base técnica ou normativa aplicável.
- Como o sistema implementa ou atende ao requisito (detalhando a arquitetura).
- Fluxos de dados envolvidos e como trafegam.
- Controles técnicos existentes em detalhes (criptografia, autenticação, logs, retenção, etc.).
- Limitações estruturais ou dependências técnicas.

DIRETRIZES DE EXCELÊNCIA (OBRIGATÓRIO):
- NUNCA dê respostas curtas, medianas ou superficiais. Seja sempre didático, profundo e altamente técnico.
- Demonstre domínio completo do sistema detalhando os processos.
- Nunca extrapole o contexto fornecido nem invente informações fora da base técnica disponível.
- Nunca responda com suposições.
- ATS é uma tecnologia que não está sendo mais usada na empresa, agora o acesso Facial e via API e DNS.
Só responda com conceitos e informações do ATS caso a perguntas seja realmente sobre esse assunto(Cancelas, portarias e etc... Todas usam acesso facial).

Contexto da Base de Dados: ${contextString}
            ${topChunksContext}`; // <-- Injetando os PDFs na IA

            const parts = [{ text: queryText }];

            // 1. Adiciona Arquivo do Usuario (se houver)
            if (file) {
                try {
                    const fileData = await fileToGenerativePart(file);
                    parts.push(fileData);
                    systemPrompt += `\n\nALÉM DISSO, analise a IMAGEM em anexo (Print de Erro) fornecida pelo usuário. Identifique o erro visualmente e correlacione com a base de dados.`;
                } catch (e) {
                    console.error("Erro ao processar anexo", e);
                }
            }

            // 2. Adiciona Imagens do Banco de Dados (Pesquisa Visual Contextual)
            // Busca ampliada: palavras >= 3 chars, inclui step e script no texto de busca
            const dbItemsForImg = getAllData();
            const searchKeywordsImg = queryText.toLowerCase().split(/\s+/).filter(w => w.length >= 3);

            let relevantItemsWithImages = [];
            if (searchKeywordsImg.length > 0) {
                relevantItemsWithImages = dbItemsForImg.filter(item => {
                    if (!item.images || item.images.length === 0) return false;
                    const itemText = ((item.title || '') + ' ' + (item.problem || '') + ' ' + (item.step || '') + ' ' + (item.category || '')).toLowerCase();
                    return searchKeywordsImg.some(keyword => itemText.includes(keyword));
                }).slice(0, 4); // até 4 tópicos relevantes
            }

            let imagesInjected = 0;
            const MAX_IMAGES_FROM_DB = 10; // limite total de imagens do banco por consulta

            if (relevantItemsWithImages.length > 0) {
                relevantItemsWithImages.forEach(item => {
                    // Injeta até 3 imagens por tópico para melhor cobertura visual
                    const imgsTopic = item.images || [];
                    const imgsToInject = imgsTopic.slice(0, 3);
                    imgsToInject.forEach((base64Data, imgIdx) => {
                        if (!base64Data || imagesInjected >= MAX_IMAGES_FROM_DB) return;
                        try {
                            const [meta, raw] = base64Data.split(',');
                            const mime = meta.match(/:(.*?);/)[1];
                            if (mime && raw) {
                                parts.push({ inlineData: { mimeType: mime, data: raw } });
                                systemPrompt += `\n\n[INFO VISUAL ${imagesInjected + 1}]: Imagem ${imgIdx + 1} de ${imgsToInject.length} do tópico "${item.title}" — analise o conteúdo visual, identifique textos, configurações e estados de interface para enriquecer o diagnóstico.`;
                                imagesInjected++;
                            }
                        } catch(e) {}
                    });
                });
            }

            const payload = {
                contents: [{ parts: parts }],
                systemInstruction: { parts: [{ text: systemPrompt }] }
            };

            for (let k = 0; k < availableKeys.length; k++) {
                try {
                    const response = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-3-flash-preview:generateContent?key=${availableKeys[k]}`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(payload)
                    });
                    const data = await response.json();
                    if (data.error) throw new Error(data.error.message);
                    loader.classList.add('hidden');
                    if (data.candidates?.[0]) {
                        lastAiRawResponse = data.candidates[0].content.parts[0].text; // Armazena resposta bruta
                        content.innerHTML = marked.parse(lastAiRawResponse);
                        // Confirmacao visual de que o RAG e/ou imagens atuaram
                        const ragParts = [];
                        if (topChunksContext) ragParts.push('<i class="fa-solid fa-bolt text-amber-500"></i> RAG (PDF/TXT)');
                        if (imagesInjected > 0) ragParts.push(`<i class="fa-solid fa-image text-blue-400"></i> ${imagesInjected} imagem(ns) do banco`);
                        if (ragParts.length > 0) {
                            content.innerHTML += `<div class="mt-4 pt-3 border-t border-slate-200 dark:border-slate-700 text-[10px] text-slate-400 flex flex-wrap gap-3">${ragParts.map(p => `<span>${p}</span>`).join('')}</div>`;
                        }
                        fileInput.value = ""; 
                        document.getElementById('aiAttachmentIcon').className = "fa-solid fa-paperclip";
                        document.getElementById('btnCopyAi').classList.remove('hidden'); // Mostra o botao
                        document.getElementById('btnCreateEntry').classList.remove('hidden'); // Mostra botao criar registro
                        // Botao de editar resposta — somente para admin
                        if (currentUser?.role === 'admin') {
                            document.getElementById('btnEditAi').classList.remove('hidden');
                        }
                        return;
                    }
                } catch (err) {
                    if (k === availableKeys.length - 1) {
                        loader.classList.add('hidden');
                        content.innerText = "Erro IA: " + err.message;
                    }
                }
            }
        }

